generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  platform    String
  url         String?
  description String?
  category    String?
  price       Float?
  uv          Int      @default(0)
  gmv         Float    @default(0)
  createdAt   DateTime @default(now())

  contents  Content[]
  posts     Post[]
  mentions  Mention[]
}

model Content {
  id        String   @id @default(cuid())
  productId String
  type      String
  title     String?
  content   String
  imageUrl  String?
  imageAlt  String?
  imagePrompt String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Post {
  id        String   @id @default(cuid())
  productId String
  platform  String
  contentId String?
  contentSnapshot String?
  imageUrl  String?
  status    String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Mention {
  id        String   @id @default(cuid())
  productId String
  aiSource  String
  count     Int      @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, aiSource])
  @@index([productId])
}

model StrategyAnalysis {
  id          String   @id @default(cuid())
  keyword     String
  location    String   @default("2156")
  language    String   @default("zh-cn")
  status      String   @default("pending")
  serpResults String?
  pageTypeDistribution String?
  competitors String?
  strategy    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

